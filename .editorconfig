root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.cs]
indent_style = space
indent_size = 4

[*.{ts,js,json}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{csproj,slnx,props,targets}]
indent_style = space
indent_size = 2

# Test data files are byte-exact expected outputs (BOM + CRLF significant).
# Editors must never normalize line endings, trim whitespace, or re-encode them.
[RightWaySqlFormatter.Tests/Data/**]
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
charset = unset
